{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Ocelot": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ],
    "Properties": {
      "ApplicationName": "Api.Gateway"
    }
  },
  "ConnectionStrings": {
    "Redis": "localhost:6379"
  },
  "JwtConfiguration": {
    "Secret": "TU_SECRET_MINIMO_32_CARACTERES",
    "Issuer": "Api.Auth",
    "Audience": "Api.Exchange"
  }
}